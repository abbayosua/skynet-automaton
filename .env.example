# ─── Skynet Automaton ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── OpenAI / DeepSeek API ───────────────────────────────────
# Your API key (OpenAI, DeepSeek, etc. depending on model)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: custom API base URL (e.g., for OpenRouter, local LLM)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ─── Blockchain / USDC Wallet ─────────────────────────────────
# RPC URL for Base network (required for USDC balance checks
# and x402 micropayments). Get a free one at:
#   https://www.alchemy.com/  or  https://infura.io/
# Default: public Base RPC (rate-limited).
# AUTOMATON_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Default Model ───────────────────────────────────────────
# Model to use for inference (default: deepseek-v4-flash)
# INFERENCE_MODEL=deepseek-v4-flash

# ─── Logging ─────────────────────────────────────────────────
# LOG_LEVEL=info

# ─── Social Relay (optional) ─────────────────────────────────
# SOCIAL_RELAY_URL=https://social.conway.tech

# ─── Conway API (optional, for cloud sandbox) ────────────────
# CONWAY_API_KEY=
# CONWAY_API_URL=https://api.conway.tech
